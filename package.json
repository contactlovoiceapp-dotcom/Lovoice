    "@tanstack/react-query": "^5.100.6",
    "expo": "~54.0.33",
    "expo-crypto": "~15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.8.0",
    "nativewind": "^4.2.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
