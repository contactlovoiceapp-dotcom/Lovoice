# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*
!.env.example

# dev-only scripts — contain or assume secrets, never commit
scripts/reset-dev-account.ts

# Google Play API (EAS Submit) — never commit
google-play-service-account.json

# typescript
*.tsbuildinfo

# generated native folders
/ios
/android

# Deno lockfile generated by `npm run test:edge` (edge function deps are version-pinned)
deno.lock
